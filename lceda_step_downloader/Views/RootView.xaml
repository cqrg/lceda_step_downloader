<hc:Window x:Class="lceda_step_downloader.Views.RootView"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:viewModels="clr-namespace:lceda_step_downloader.ViewModels"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:s="https://github.com/canton7/Stylet"
           xmlns:HelixToolkit="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
           xmlns:local="clr-namespace:lceda_step_downloader"
           mc:Ignorable="d"
           d:DataContext="{d:DesignInstance Type=viewModels:RootViewModel}"
           Title="{Binding Title}"
           WindowStartupLocation="CenterScreen"
           ShowTitle="True"
           Height="750"
           Width="1100">
    <Window.Resources>
        <viewModels:IndexConverter x:Key="MyIndexConverter"/>
        <viewModels:BooleanOrConverter x:Key="MyallowdownloadConverter"/>
    </Window.Resources>
    <Grid Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=ActualWidth}"
          Height="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=ActualHeight}">
        <Grid Margin="0,5,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：搜索面板 ===== -->
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <hc:ComboBox
                        HorizontalAlignment="Stretch"
                        Grid.Column="0"
                        Style="{StaticResource ComboBoxExtend}"
                        Margin="5,0,0,0"
                        ItemsSource="{Binding SearchSites}"
                        SelectedItem="{Binding SSite}"
                        DisplayMemberPath="Site">
                    </hc:ComboBox>
                    <hc:SearchBar
                        HorizontalAlignment="Stretch"
                        Margin="5,0,5,0"
                        Grid.Column="1"
                        IsRealTime="False"
                        Command="{s:Action DoSearch}"
                        CommandParameter="{Binding Text,RelativeSource={RelativeSource Self}}">
                    </hc:SearchBar>
                </Grid>
                <Grid Grid.Row="1" Margin="0,0,0,5">
                    <ListView
                        HorizontalAlignment="Stretch"
                        Margin="0,5,5,0"
                        ItemsSource="{Binding SearchResult.result}"
                        Grid.Row="0"
                        SelectedItem="{Binding Selecteditem}"
                        SelectionChanged="{s:Action OnResultSelection}">
                        <ListView.Resources>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Style>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource ListViewItemBaseStyle}">
                                <Setter Property="MinHeight" Value="20"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="40" DisplayMemberBinding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ListViewItem}}, Converter={StaticResource MyIndexConverter}}"/>
                                <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding Path=display_title}"/>
                                <GridViewColumn Width="Auto" DisplayMemberBinding="{Binding attributes.Manufacturer}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <!-- ===== 右侧：预览面板 ===== -->
            <Grid Grid.Column="1" Margin="5,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 2x2 预览网格 第一行 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左上：图片预览 -->
                    <Border Grid.Column="0" BorderBrush="#ccc" BorderThickness="0,0,1,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="器件图片" FontSize="12"
                                       HorizontalAlignment="Center" Foreground="#666" Margin="0,2,0,0"/>
                            <Image Grid.Row="1" Source="{Binding ImageSource}"
                                   Stretch="Uniform" Margin="5"/>
                        </Grid>
                    </Border>

                    <!-- 右上：原理图预览 -->
                    <Border Grid.Column="1" BorderBrush="#ccc" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="原理图" FontSize="12"
                                       HorizontalAlignment="Center" Foreground="#666" Margin="0,2,0,0"/>
                            <WebBrowser Grid.Row="1" Margin="2"
                                        local:WebBrowserHelper.BindableSource="{Binding SchematicSvgUri}">
                                <WebBrowser.Style>
                                    <Style TargetType="WebBrowser">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSchematic}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WebBrowser.Style>
                            </WebBrowser>
                            <TextBlock Grid.Row="1" Text="暂无原理图"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#999" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSchematic}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 2x2 预览网格 第二行 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左下：封装预览 -->
                    <Border Grid.Column="0" BorderBrush="#ccc" BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="封装" FontSize="12"
                                       HorizontalAlignment="Center" Foreground="#666" Margin="0,2,0,0"/>
                            <WebBrowser Grid.Row="1" Margin="2"
                                        local:WebBrowserHelper.BindableSource="{Binding FootprintSvgUri}">
                                <WebBrowser.Style>
                                    <Style TargetType="WebBrowser">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFootprint}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WebBrowser.Style>
                            </WebBrowser>
                            <TextBlock Grid.Row="1" Text="暂无封装"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="#999" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFootprint}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- 右下：3D模型预览 -->
                    <Border Grid.Column="1" BorderBrush="#ccc" BorderThickness="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="3D模型" FontSize="12"
                                       HorizontalAlignment="Center" Foreground="#666" Margin="0,2,0,0"/>
                            <HelixToolkit:HelixViewport3D Grid.Row="1" ZoomExtentsWhenLoaded="True"
                                                          IsHeadLightEnabled="False">
                                <HelixToolkit:DefaultLights/>
                                <ModelVisual3D Content="{Binding MyModelGroup}"/>
                                <HelixToolkit:GridLinesVisual3D Width="8" Length="8"
                                                                MinorDistance="1" MajorDistance="1"
                                                                Thickness="0.01"/>
                            </HelixToolkit:HelixViewport3D>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 按钮区 -->
                <Grid Grid.Row="2" Margin="0,5,0,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <!-- 第一排：3D相关操作 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" x:Name="showobj"
                                Command="{s:Action DownloadObj}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                                    <Setter Property="Content" Value="预览3D"/>
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Selecteditem.attributes._3D_Model}"
                                                     Value="{x:Null}">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Content" Value="暂无3D"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="1" x:Name="downloadstep"
                                Command="{s:Action DownloadStep}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource MyallowdownloadConverter}">
                                    <Binding ElementName="showobj" Path="IsEnabled"/>
                                    <Binding Path="DownloadAllowed"/>
                                </MultiBinding>
                            </Button.IsEnabled>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="下载STEP" FontSize="13"/>
                                <hc:LoadingCircle Height="16" Width="16" VerticalAlignment="Center"
                                                  Margin="5,0,0,0" DotDiameter="3" DotInterval="10">
                                    <hc:LoadingCircle.Style>
                                        <Style TargetType="hc:LoadingCircle"
                                               BasedOn="{StaticResource LoadingBaseStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DownloadAllowed}" Value="True">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </hc:LoadingCircle.Style>
                                </hc:LoadingCircle>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{s:Action DownloadSchematic}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                                    <Setter Property="Content" Value="下载原理图"/>
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSchematic}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Content" Value="无原理图"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="3"
                                Command="{s:Action DownloadFootprint}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                                    <Setter Property="Content" Value="下载封装"/>
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasFootprint}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Content" Value="无封装"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- 第二排：规格书 + 打开目录 -->
                    <Grid Grid.Row="1" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{s:Action OpenDatasheet}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                                    <Setter Property="Content" Value="打开规格书"/>
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDatasheet}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Content" Value="无规格书"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="1"
                                Command="{s:Action DownloadDatasheet}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center">
                            <Button.Style>
                                <Style BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                                    <Setter Property="Content" Value="下载规格书"/>
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasDatasheet}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Content" Value="无规格书"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{s:Action OpenStepFolder}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center"
                                Content="STEP目录"/>

                        <Button Grid.Column="3"
                                Command="{s:Action OpenSymbolsFolder}"
                                FontSize="13" Height="26" Margin="3,0,3,0"
                                Padding="0" VerticalAlignment="Center"
                                Content="全部目录"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- Growl 通知容器 -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalAlignment="Right" Margin="0,0,0,300">
            <StackPanel hc:Growl.GrowlParent="True" Margin="0,10,10,10"/>
        </ScrollViewer>
    </Grid>
</hc:Window>
